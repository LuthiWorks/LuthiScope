# LuthiScope configuration (copy to .env and fill in; .env is gitignored)

# Root directory under which run directories live. Read-only to LuthiScope.
# Each run dir contains training_log.jsonl / m9_action_log.jsonl / run_config.json.
LUTHISCOPE_RUNS_DIR=/path/to/runs

# LuthiScope's own home: derived DB, exports, triggered-study outputs.
LUTHISCOPE_HOME=/path/to/LuthiScope

# Backend bind address (local-only by default).
LUTHISCOPE_HOST=127.0.0.1
LUTHISCOPE_PORT=8800

# Run-registry handshake file. The trainer announces active run dirs here (it
# writes; LuthiScope only reads). Lets an active run be discovered with no
# RUNS_DIR config. Default: ~/.luthiscope/runs.json. See docs/RUN_REGISTRY.md.
LUTHISCOPE_REGISTRY=~/.luthiscope/runs.json
